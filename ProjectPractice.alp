					<Id>1775460121050</Id>
					<Name><![CDATA[Waiting]]></Name>
					<X>600</X><Y>230</Y>
					<Label><X>10</X><Y>10</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[waitingTime = uniform_discr(1, 31);
//для статистики учитываются случаи, когда 
//водитель дождался клиента
if (waitingTime <= 30) {
	main.totalWaitingTime += waitingTime; 
}]]></EntryAction>
