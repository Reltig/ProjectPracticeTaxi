				<StatechartElement Class="Transition" ParentState="ROOT_NODE">
					<Id>1762516633958</Id>
					<Name><![CDATA[transitionToFinish]]></Name>
					<X>650</X><Y>180</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<Points>
						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>0</X><Y>50</Y></Point>
					</Points>
					<IconOffset>20.0</IconOffset>
					<Properties Source="1762514452820" Target="1775460121050" Trigger="arrival">
						<Action><![CDATA[if (order != null) {
	main.remove_orderAnimationsStart(order.imageStart);
	
	if (order.isHighestPriority){
		main.reactionTimeFastTotal += (time() - order.startTime);
		main.reactionTimeMedium = (double)main.reactionTimeFastTotal / main.priorityOrdersCount;
	}
}]]></Action>
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Condition><![CDATA[true]]></Condition>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<MessageType><![CDATA[Object]]></MessageType>
						<DefaultTransition>true</DefaultTransition>
						<FilterType><![CDATA[unconditionally]]></FilterType>
						<EqualsExpression><![CDATA["text"]]></EqualsExpression>
