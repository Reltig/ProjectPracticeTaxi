			<Events>
				<Event>
					<Id>1762515203138</Id>
					<Name><![CDATA[createOrder]]></Name>
					<X>-170</X><Y>20</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="rate" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[ordersIntensity]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1762515203136</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1762588800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[triangular(1, 3)]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[projectpractice.Order order = new projectpractice.Order();
Endpoint start = endpoints.random();
order.start = start;
Endpoint finish = endpoints.random();
while (order.start == finish) finish = endpoints.random();
order.finish = finish;
order.isHighestPriority = random.nextBoolean();
order.isChildSeat = random.nextBoolean();
order.type = ServiceType.random(random);
order.startTime = time();

OrderStart orderAnimationStart = add_orderAnimationsStart();
order.imageStart = orderAnimationStart;
orderAnimationStart.isHighestPriority = order.isHighestPriority; 

OrderEnd orderAnimationEnd = add_orderAnimationsEnd();
order.imageEnd = orderAnimationEnd;

orderAnimationStart.imageEnd = orderAnimationEnd;

send(start, orderAnimationStart);
send(finish, orderAnimationEnd);

schedule(order);]]></Action>
				</Event>
				<Event>
					<Id>1775458799090</Id>
					<Name><![CDATA[refuseOrder]]></Name>
					<X>-170</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="rate" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[2]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775458799088</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1762588800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[triangular(1, 3)]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[//выбираем заказ, которому еще не назначен водитель
Order refuseOrder = orders.stream()
	.filter(order -> order.finishTime == 0.0 && 
			order.vechicle == null)
	.findFirst()
	.orElse(null);
//если такой заказ найден, удаляем его из очереди заказов
if (refuseOrder != null) {
    int index = orders.indexOf(refuseOrder);
    if (index != -1) {
        orders.remove(index);
        refusedOrders++;
    }
}]]></Action>
				</Event>
				<Event>
					<Id>1776949303452</Id>
					<Name><![CDATA[setTrafficLevel]]></Name>
					<X>-310</X><Y>20</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1776949303450</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1777017600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[String sheetName = dayType.toString(); // название листа зависит от дня недели
int columnTraffic = 2; // номер колонки с уровнем пробок
int columnPrecipitation = 3; // номер колонки с уровнем осадков
int columnDemand = 4;  // номер колонки с уровнем спроса 
 

// считываем уровень трафика из файла Excel
trafficLevel = (int)trafficWeather.getCellNumericValue(sheetName, currentRowTraffic, columnTraffic);

// считываем уровень спроса (true - высокий)
var highDemandStr = trafficWeather.getCellStringValue(sheetName, currentRowTraffic, columnDemand);
// приводим к типу boolean (без учета регистра)
highDemand = "true".equalsIgnoreCase(highDemandStr);

//считываем уровень осадков
var precipitation = trafficWeather.getCellStringValue(sheetName, 
						currentRowTraffic, columnPrecipitation);
if ("-".equals(precipitation)) precipitationLevel = 0.0;
else precipitationLevel = Double.parseDouble(precipitation);

setOrdersIntensity();

// при следующем срабатывании события будет считана следующая строка файла
currentRowTraffic += 1;]]></Action>
				</Event>
				<Event>
					<Id>1776975569375</Id>
					<Name><![CDATA[countCarsByService]]></Name>
					<X>-310</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1776975569373</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1777017600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[economCarsCount = filter(vehicles, v -> v.type == ServiceType.Econom).size();
comfortCarsCount = filter(vehicles, v -> v.type == ServiceType.Comfort).size();
businessCarsCount = filter(vehicles, v -> v.type == ServiceType.Business).size();]]></Action>
				</Event>
				<Event>
					<Id>1777227813359</Id>
					<Name><![CDATA[writeLogs]]></Name>
					<Description><![CDATA[Пишет логи в файл статистики]]></Description>
					<X>-310</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MINUTE]]></Unit>
						</Rate>
						<Id>1777227813357</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1777276800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[15]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[String[] headers = { //заголовки таблицы Excel
    "runID", "dayType", "time", "trafficLevel", "highDemand", "precipitationLevel",
    "ordersIntensity",
    "mediumTravelCost", "mediumCostEconom", "mediumCostComfort", "mediumCostBusiness",
    "mediumIncome",
    "completedOrders", "completedOrdersByCar", 
    "mediumTravelTime", "mediumWaitingTime", "mediumUrgentReactTime",
    "allWorkingCars", "currentBusyCars", "emptyMileage",
    "ordersLost", "ordersRefused"
};
String day = dayType.toString();//тип дня
//текущее модельное время (часы и минуты)
String time = String.format("%02d:%02d", getHourOfDay(), getMinute());
//считываем уровень осадков
var precipitation = trafficWeather.getCellStringValue(day, currentRowTraffic, 3);
//средняя стоимость поездки
var mediumTravelCost = completedOrders > 0? ordersIncome / completedOrders : 0;
//средний доход водителя по всем категориям
var mediumIncome =  workingVehicles > 0 ? 
	(totalIncomeEconom+totalIncomeComfort+totalIncomeBusiness) / workingVehicles : 0;
var mediumIncomeEconom = economCarsCount > 0 ?  //средний доход эконом
   (totalIncomeEconom) / economCarsCount : 0;
var mediumIncomeComfort = comfortCarsCount > 0 ? //средний доход комфорт
   (totalIncomeComfort) / comfortCarsCount : 0;
var mediumIncomeBusiness = businessCarsCount > 0 ? //средний доход бизнес
   (totalIncomeBusiness) / businessCarsCount : 0; 
   
// сред. время ожидания клиента
var mediumWaitingTime = startedOrders == 0? 0 : totalWaitingTime / startedOrders ;
//значения для всех столбцов
Object[] values = {
	runDateTime, day, time, trafficLevel, highDemand, precipitation, ordersIntensity,
	mediumTravelCost,
	mediumIncome, mediumIncomeEconom, mediumIncomeComfort, mediumIncomeBusiness,
	completedOrders, completedOrdersPerVehicle,
	mediumOrderDuration, mediumWaitingTime, reactionTimeMedium,
	workingVehicles, busyVehicles, emptyMileage,
	lostOrders, refusedOrders
};

if (values.length == headers.length){
    //заполняем столбцы Excel
	for (int i = 0; i < headers.length; i++) {
	    // Записываем значение в i-й столбец на первом листе
	    stats.setCellValue(values[i].toString(), 1, currentStatsRow, i+1);
	}
	currentStatsRow++; //увеличиваем номер строки для следующей записи
    stats.writeFile(); // сохраняем все изменения
}
else{ 
	traceln("Невозможно записать файл статистики, кол-во заголовков и значений разное!");
}]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1762512566171</Id>
					<Name><![CDATA[schedule]]></Name>
					<X>-170</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[order]]></Name>
						<Type><![CDATA[Order]]></Type>
					</Parameter>
					<Body><![CDATA[Vehicle chosen = null;
double minDistance = Double.MAX_VALUE;

for (Vehicle v: vehicles) {
	if (v.order != null) continue;
	if (order.isChildSeat && !v.hasChildSeat) continue;
	double newDistance = v.distanceTo(order.start.getLatitude(), order.start.getLongitude());
	if (newDistance < minDistance){
		minDistance = newDistance;
		chosen = v;
	}
}
if (chosen != null){
	if (order.isHighestPriority){
	    priorityOrdersCount += 1;
		send(order, chosen);
	}
	if (!order.isHighestPriority && orders.size() == 0) send(order, chosen);
}
else orders.push(order);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1764860641301</Id>
					<Name><![CDATA[prepare]]></Name>
					<X>-450</X><Y>20</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[List<Point2[]> polygons = new ArrayList<Point2[]>();
try {
    JSONObject object = (JSONObject)(new JSONParser().parse(new FileReader("borders.json")));
    JSONArray features = (JSONArray)object.get("features");
    for(Object featureObj: features){
    	JSONObject feature = (JSONObject)featureObj;
    	JSONObject geometry = (JSONObject)feature.get("geometry");
    	JSONArray coordinatesOuter = (JSONArray)geometry.get("coordinates");
    	JSONArray coordinates = (JSONArray)coordinatesOuter.get(0);
    	List<Point2> verticles = new ArrayList<Point2>();
    	Point2[] points = (Point2[])coordinates
    		.stream()
    		.map(coords -> {
    			JSONArray pair = (JSONArray)coords;
    			return new Point2((double)pair.get(0), (double)pair.get(1));
    		})
    		.toArray(Point2[]::new);
    	polygons.add(points);
    }
} catch (Exception e) {
    e.printStackTrace();
}

double xStep = (topRight.getLongitude()-center.getLongitude())/horizontalNodes
	+ (bottomLeft.getLongitude()-center.getLongitude())/verticalNodes;
double yStep = (bottomLeft.getLatitude()-center.getLatitude())/verticalNodes
 	+ (topRight.getLatitude()-center.getLatitude())/horizontalNodes;
Point2 d1 = new Point2((topRight.getLatitude()-center.getLatitude())/verticalNodes, (topRight.getLongitude()-center.getLongitude())/verticalNodes);
Point2 d2 = new Point2((bottomLeft.getLatitude()-center.getLatitude())/horizontalNodes, (bottomLeft.getLongitude()-center.getLongitude())/horizontalNodes);
//Point2[][] polygonsArray = (Point2[][])polygons.toArray();
for(int i = 0; i < horizontalNodes + 1; i++) {
	for(int j = 0; j < verticalNodes + 1; j++) {
		Point2 newPos = new Point2(center.getLatitude() + d1.x * j + d2.x * i, center.getLongitude()  + d1.y * j + d2.y * i);		
		if (pointInPolygon(polygons, newPos))
		 continue;
		Endpoint e = add_endpoints();
		e.setXY(newPos.x, newPos.y);
		//e.moveTo(newPos.x, newPos.y);
	}
}
Point2[] testPolygon = new Point2[]{new Point2(-1.0, 1.0), new Point2(1.0, 1.0), new Point2(1.0, -1.0), new Point2(-1.0, -1.0)};
List<Point2[]> test = new ArrayList<Point2[]>();
test.add(testPolygon);
Point2 in = new Point2(0.0, 0.0);
Point2 out = new Point2(2.0, 0.0);
System.out.println(pointInPolygon(test, in));
System.out.println(pointInPolygon(test, out));]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1765469077453</Id>
					<Name><![CDATA[pointInPolygon]]></Name>
					<X>-450</X><Y>50</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[polygons]]></Name>
						<Type><![CDATA[List<Point2[]>]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[point]]></Name>
						<Type><![CDATA[Point2]]></Type>
					</Parameter>
					<Body><![CDATA[for (Point2[] polygon : polygons) {
    if (isPointInPolygon(polygon, point.x, point.y)) {
        return true;
    }
}
return false;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1778079438690</Id>
					<Name><![CDATA[isPointInPolygon]]></Name>
					<X>-450</X><Y>80</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[polygon]]></Name>
						<Type><![CDATA[Point2[]]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[x]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[y]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[int n = polygon.length;
if (n < 3) {
    return false;
}

boolean inside = false;
for (int i = 0, j = n - 1; i < n; j = i++) {
    double xi = polygon[i].x, yi = polygon[i].y;
    double xj = polygon[j].x, yj = polygon[j].y;

    if (((yi > y) != (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
        inside = !inside;
    }
}
return inside;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1778746569219</Id>
					<Name><![CDATA[setOrdersIntensity]]></Name>
					<Description><![CDATA[Устанавливает интенсивность появления заказов]]></Description>
					<X>-640</X><Y>310</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double baseRate = 120.0;
// уровень пробок
double trafficMultiplier = getTrafficMiltiplier(); 
 //уровень спроса
double demandMultiplier = highDemand ? 1.7 : 1.0;
// погодные условия
double weatherMultiplier = getWeatherMultiplier(); 
// время суток
int hour = getHourOfDay();
double timeMultiplier = (hour >= 16 && hour <= 20) ? 1.25 : 1.0;
//считаем интенсивность появления заказов
var intensity = baseRate * trafficMultiplier * demandMultiplier * 
	    weatherMultiplier * timeMultiplier;
	   
ordersIntensity = intensity;]]></Body>
				</Function>
