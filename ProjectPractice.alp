			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1762517283604</Id>
					<Name><![CDATA[getOrderFromPool]]></Name>
					<X>40</X><Y>330</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[double minDistance = Double.POSITIVE_INFINITY;
int i = 0;
orderIndex = 0;
Order closestOrder = null;
traceln("get from pool");

// Получаем список заказов с высшим приоритетом
List<Order> priorityOrders = main.orders.stream()
    .filter(o -> checkOrderCharacteristics(o, true))
    .toList();

if (priorityOrders.size() > 0) {
    // Поиск заказа с минимальным расстоянием среди приоритетных
   for (Order o: main.orders) {
		double newDistance = this.distanceTo(o.start.getLatitude(), o.start.getLongitude());
		if (newDistance < minDistance){
			minDistance = newDistance;
			closestOrder = o;
		}
	}
}
else {// Поиск заказа с минимальным расстоянием среди неприоритетных (false)
	for (Order o: main.orders) {
		if (!checkOrderCharacteristics(o, false)) continue;
		double newDistance = this.distanceTo(o.start.getLatitude(), o.start.getLongitude());
		if (newDistance < minDistance){
			minDistance = newDistance;
			closestOrder = o;
		}
	}
}
if (closestOrder != null){
	orderIndex = main.orders.indexOf(closestOrder);
	main.orders.remove(orderIndex);
	order = closestOrder;
	send(order, this);
}]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1766158332375</Id>
					<Name><![CDATA[checkOrderCharacteristics]]></Name>
					<X>40</X><Y>300</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[order]]></Name>
						<Type><![CDATA[Order]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[isPriority]]></Name>
						<Type><![CDATA[boolean]]></Type>
					</Parameter>
					<Body><![CDATA[return order.isHighestPriority == isPriority && order.type == this.type && order.isChildSeat == this.hasChildSeat;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775455832707</Id>
					<Name><![CDATA[getEffectiveSpeed]]></Name>
					<X>40</X><Y>360</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[speedKmh]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[return speedKmh / (1 + (main.trafficLevel - 1) * 0.15);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775456589518</Id>
					<Name><![CDATA[setUpParams]]></Name>
					<X>40</X><Y>390</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (type == ServiceType.Econom) {
	ratePerKm = 16;
	ratePerMin = 6;
	minFare = 95;
	freeWaitingTime = 2;
	waitingCostPerMin = 9;
} else if (type == ServiceType.Comfort) {
	ratePerKm = 19.2;
	ratePerMin = 7.2;
	minFare = 114;
	freeWaitingTime = 3;
	waitingCostPerMin = 11;
} else if (type == ServiceType.Business) {
	ratePerKm = 23;
	ratePerMin = 10;
	minFare = 300;
	freeWaitingTime = 3;
	waitingCostPerMin = 13;
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775457254393</Id>
					<Name><![CDATA[getOrderIncome]]></Name>
					<X>40</X><Y>420</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[distanceKm]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[travelTimeMin]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[highDemand]]></Name>
						<Type><![CDATA[boolean]]></Type>
					</Parameter>
					<Body><![CDATA[double baseFare = distanceKm * ratePerKm + travelTimeMin * ratePerMin;
double fareWithMin = max(minFare, baseFare);
double demandMult = highDemand ? 2.4 : 1.0;
double trafficMult = getTrafficMultiplier();
double finalFare = fareWithMin * trafficMult * demandMult;
double waitingIncome = waitingTime <= freeWaitingTime ? 0 : (waitingTime - freeWaitingTime) * waitingCostPerMin; 
return finalFare + waitingIncome;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775457543361</Id>
					<Name><![CDATA[setEffectiveSpeed]]></Name>
					<X>40</X><Y>450</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[setSpeed(getEffectiveSpeed(main.carsSpeed), SpeedUnits.KPH);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775460988010</Id>
					<Name><![CDATA[calculateRefusalIncome]]></Name>
					<X>40</X><Y>480</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[waitingTime]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[return  minFare + waitingTime * waitingCostPerMin;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1775463334456</Id>
					<Name><![CDATA[getTrafficMultiplier]]></Name>
					<X>40</X><Y>510</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[var trafficLevel = main.trafficLevel;
if (trafficLevel >= 9) return 2.2;
if (trafficLevel >= 7) return 1.7;
if (trafficLevel >= 5) return 1.3;
return 1.0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1776973852276</Id>
					<Name><![CDATA[updateTotalIncome]]></Name>
					<Description><![CDATA[Обновляет значение суммарного дохода всех водителей одного типа сервиса]]></Description>
					<X>210</X><Y>420</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[value]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[if (type == ServiceType.Econom) main.totalIncomeEconom += value;
else if (type == ServiceType.Comfort) main.totalIncomeComfort += value;
else if (type == ServiceType.Business) main.totalIncomeBusiness += value;
income += value;]]></Body>
				</Function>
			</Functions>
