					<Name><![CDATA[ToStart]]></Name>
					<X>600</X><Y>150</Y>
					<Label><X>10</X><Y>10</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[main.busyVehicles++;
distanceToStart = distanceByRoute(order.start)/1000;
setEffectiveSpeed();
moveTo(order.start);]]></EntryAction>
						<ExitAction><![CDATA[main.emptyMileage += distanceToStart;]]></ExitAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
				<StatechartElement Class="State" ParentState="ROOT_NODE">
					<Id>1762516564205</Id>
					<Name><![CDATA[ToFinish]]></Name>
					<X>600</X><Y>300</Y>
					<Label><X>10</X><Y>10</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties Width="100" Height="30">
						<EntryAction><![CDATA[//для посчета среднего времени ожидания клиентов
main.startedOrders += 1;

setEffectiveSpeed();
distanceToFinish = distanceByRoute(order.finish)/1000;
moveTo(order.finish);]]></EntryAction>
						<ExitAction><![CDATA[main.busyVehicles--;

//если автомобиль впервые выезжает на вызов и пассажир уже в машине,
//то включаем автомобиль в подсчет статистики 
//по кол-ву выполненных заказов на борт
if (!inWork) {
	main.workingVehicles += 1;
	inWork = true;
}]]></ExitAction>
						<FillColor/>
					</Properties>
				</StatechartElement>
