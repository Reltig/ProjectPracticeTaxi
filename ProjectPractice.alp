				<StatechartElement Class="Transition" ParentState="ROOT_NODE">
					<Id>1762516881351</Id>
					<Name><![CDATA[transition1]]></Name>
					<X>650</X><Y>330</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<Points>
						<Point><X>0</X><Y>0</Y></Point>
						<Point><X>0</X><Y>40</Y></Point>
					</Points>
					<IconOffset>20.0</IconOffset>
					<Properties Source="1762516564205" Target="1762516979244" Trigger="arrival">
						<Action><![CDATA[main.completedOrders+=1;

order.finishTime = time();
order.duration = order.finishTime - order.startTime;
main.allOrdersDuration += order.duration;
main.orderDurationsDataset.add(order.duration); //для гистограммы
main.mediumOrderDuration = main.allOrdersDuration / main.completedOrders;
//доход водителя с поездки
var newIncome = getOrderIncome(distanceToFinish, order.duration, main.highDemand);
main.ordersIncome += newIncome; //суммарная стоимость поездки

// считаем суммарный доход для каждого вида сервиса
updateTotalIncome(newIncome);

main.remove_orderAnimationsEnd(order.imageEnd);
order = null;
//считаем среднее кол-во выполненных заказов на борт
main.completedOrdersPerVehicle = (double)main.completedOrders/main.workingVehicles;]]></Action>
